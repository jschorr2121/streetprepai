{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run --project node tests/unit",
    "test:int": "vitest run --project node tests/integration",
    "test:dom": "vitest run --project dom",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live": "STREETPREP_E2E_LIVE_AI=1 STREETPREP_E2E_AUTH=1 playwright test",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts",
    "db:pull": "node --env-file=.env.local scripts/introspect.mjs",
    "db:generate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs push",
    "db:check": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs check",
    "db:studio": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@anthropic-ai/sdk": "^0.90.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "groq-sdk": "^1.2.0",
    "inngest": "^4.4.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "openai": "^6.36.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "posthog-js": "^1.372.8",
    "posthog-node": "^5.33.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-email": "^6.1.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
