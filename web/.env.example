# StreetPrepAI environment template — copy to .env.local and fill in.
# Generated from the vars actually read in code (2026-07-16). Never commit .env.local.
# Deploys need the same values in the Vercel project env, not just this file.

# ── Supabase (required) ────────────────────────────────────────────────────────
# Project settings → API. The URL + anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used by background/admin paths (lib/supabase/admin.ts).
# Optional in dev: features that need it degrade to no-ops with a console warning.
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (required for any DB-backed page) ─────────────────────────────────
# Supabase → Database → Connection string. DATABASE_URL should be the POOLED
# (transaction-mode) string; DIRECT_URL the non-pooled one, used only by
# drizzle-kit/introspection tooling.
DATABASE_URL=postgresql://...
DIRECT_URL=

# ── AI providers ───────────────────────────────────────────────────────────────
# Server-only. Required for chat, lens, prep sheets, scoring (Anthropic) and
# transcription/resume features (OpenAI; interview transcribe falls back to a
# demo transcript without it).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Per-user monthly AI spend cap in USD. Default 20; <=0 disables the cap.
#AI_USER_MONTHLY_CAP_USD=20

# ── Upstash Redis (rate limiting) ──────────────────────────────────────────────
# Optional in dev (limiters degrade open); REQUIRED in production — AI limiters
# fail closed there when unset/unreachable.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (optional; error + performance monitoring) ─────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only: enables source-map upload so prod stack traces are readable.
#SENTRY_ORG=
#SENTRY_PROJECT=
#SENTRY_AUTH_TOKEN=

# ── PostHog (optional; analytics) ──────────────────────────────────────────────
#NEXT_PUBLIC_POSTHOG_KEY=
# Server-side key; falls back to NEXT_PUBLIC_POSTHOG_KEY when unset.
#POSTHOG_API_KEY=
# Defaults to https://us.i.posthog.com; set for the EU region or a proxy.
# The CSP in next.config.ts derives its allowed origins from this at build time.
#NEXT_PUBLIC_POSTHOG_HOST=

# ── Logging ────────────────────────────────────────────────────────────────────
# Pino level override. Defaults: info (prod) / debug (dev).
#LOG_LEVEL=info

# ── Scripts / tests only (not read by the app at runtime) ─────────────────────
# Set to 1 to let db:push / db:migrate / db:studio touch the DB (scripts/db-guard.mjs).
#ALLOW_LIVE_DB=0
# Playwright: base URL, authed specs, and live-AI specs (spend real money).
#PLAYWRIGHT_BASE_URL=http://localhost:3000
#STREETPREP_E2E_AUTH=0
#STREETPREP_E2E_LIVE_AI=0
